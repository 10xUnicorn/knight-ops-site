{
  "rewrites": [
    { "source": "/apply", "destination": "/apply.html" },
    { "source": "/apps", "destination": "/apps.html" },
    { "source": "/book", "destination": "/book.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/portal", "destination": "/portal.html" },
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/prospecting-filter-score", "destination": "/prospecting-filter-score.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
