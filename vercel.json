{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path((?!api/).+)\\.html",
      "destination": "/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:slug",
      "destination": "/blog.html"
    },
    {
      "source": "/proposal/:slug/pdf",
      "destination": "https://trpnlkntvulkjerevngm.supabase.co/functions/v1/serve-proposal?slug=:slug&dl=pdf"
    },
    {
      "source": "/proposal/:slug",
      "destination": "https://trpnlkntvulkjerevngm.supabase.co/functions/v1/serve-proposal?slug=:slug"
    },
    {
      "source": "/:path",
      "destination": "/:path.html"
    }
  ],
  "headers": [
    {
      "source": "/proposal/:slug",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        },
        {
          "key": "Content-Security-Policy",
          "value": ""
        }
      ]
    },
    {
      "source": "/proposal/:slug/pdf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/pdf"
        }
      ]
    }
  ]
}