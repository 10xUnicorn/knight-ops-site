{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path((?!api/).+)\\.html",
      "destination": "/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:slug",
      "destination": "/blog.html"
    },
    {
      "source": "/proposal/:slug/pdf",
      "destination": "/api/proposal?slug=:slug&dl=pdf"
    },
    {
      "source": "/proposal/:slug",
      "destination": "/api/proposal?slug=:slug"
    },
    {
      "source": "/:path",
      "destination": "/:path.html"
    }
  ],
  "headers": [
    {
      "source": "/api/proposal",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/proposal/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    }
  ]
}