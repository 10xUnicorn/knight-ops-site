{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path((?!api/).+)\\.html",
      "destination": "/:path",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:slug",
      "destination": "/blog.html"
    },
    {
      "source": "/proposal/:slug/pdf",
      "destination": "/proposal-viewer.html"
    },
    {
      "source": "/proposal/:slug",
      "destination": "/proposal-viewer.html"
    },
    {
      "source": "/:path",
      "destination": "/:path.html"
    }
  ]
}
