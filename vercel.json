{
  "rewrites": [
    {
      "source": "/apply",
      "destination": "/apply.html"
    },
    {
      "source": "/apps",
      "destination": "/apps.html"
    },
    {
      "source": "/book",
      "destination": "/book.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/portal",
      "destination": "/portal.html"
    },
    {
      "source": "/auth",
      "destination": "/auth.html"
    },
    {
      "source": "/blueprint",
      "destination": "/blueprint.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/careers",
      "destination": "/careers.html"
    },
    {
      "source": "/careers/:id",
      "destination": "/careers.html"
    },
    {
      "source": "/proposal/:slug",
      "destination": "/proposal-viewer.html"
    },
    {
      "source": "/proposal/:slug/pdf",
      "destination": "/proposal-viewer.html"
    },
    {
      "source": "/client-portal",
      "destination": "/client-portal.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}