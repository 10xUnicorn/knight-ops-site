<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Knight Ops | Command Center</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%230a0a0f'/%3E%3Ctext x='16' y='22' text-anchor='middle' font-size='18' fill='%23d4a843'%3E%E2%9A%94%3C/text%3E%3C/svg%3E">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
  *{margin:0;padding:0;box-sizing:border-box}
  body{
    font-family:'Inter',sans-serif;
    background:#07070b;
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    overflow:hidden;
  }
  /* Animated background */
  body::before{
    content:'';position:fixed;top:0;left:0;right:0;bottom:0;
    background:
      radial-gradient(ellipse 80% 60% at 50% -20%, rgba(212,168,67,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 80% 80%, rgba(212,168,67,0.03) 0%, transparent 50%),
      radial-gradient(ellipse 50% 50% at 20% 60%, rgba(59,130,246,0.02) 0%, transparent 50%);
    pointer-events:none;z-index:0;
  }
  /* Grid pattern */
  body::after{
    content:'';position:fixed;top:0;left:0;right:0;bottom:0;
    background-image:
      linear-gradient(rgba(212,168,67,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212,168,67,0.03) 1px, transparent 1px);
    background-size:60px 60px;
    pointer-events:none;z-index:0;
  }
  .gate-container{
    position:relative;z-index:1;
    width:100%;max-width:420px;padding:20px;
  }
  .gate-card{
    background:rgba(17,17,24,0.85);
    backdrop-filter:blur(20px);
    border:1px solid rgba(212,168,67,0.12);
    border-radius:20px;
    padding:48px 40px;
    text-align:center;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.03),
      0 20px 60px rgba(0,0,0,0.5),
      0 0 120px rgba(212,168,67,0.04);
  }
  /* Logo mark */
  .gate-mark{
    width:56px;height:56px;
    border-radius:14px;
    background:linear-gradient(135deg, rgba(212,168,67,0.15), rgba(212,168,67,0.05));
    border:1px solid rgba(212,168,67,0.2);
    display:flex;align-items:center;justify-content:center;
    margin:0 auto 24px;
    font-size:24px;
  }
  .gate-brand{
    font-size:13px;font-weight:700;
    color:#d4a843;
    letter-spacing:4px;
    text-transform:uppercase;
    margin-bottom:4px;
  }
  .gate-title{
    font-size:22px;font-weight:300;
    color:#e4e4e7;
    margin-bottom:4px;
    letter-spacing:-0.3px;
  }
  .gate-sub{
    color:#52525b;font-size:13px;
    margin-bottom:36px;
    font-weight:400;
  }
  .input-group{
    position:relative;
    margin-bottom:16px;
  }
  .gate-input{
    width:100%;
    background:rgba(10,10,15,0.8);
    border:1px solid rgba(30,30,46,0.8);
    color:#e4e4e7;
    padding:14px 20px 14px 44px;
    border-radius:12px;
    font-size:15px;
    font-family:inherit;
    outline:none;
    transition:all .25s ease;
  }
  .gate-input:focus{
    border-color:rgba(212,168,67,0.5);
    box-shadow:0 0 0 3px rgba(212,168,67,0.08);
  }
  .gate-input::placeholder{color:#3f3f46}
  .input-icon{
    position:absolute;left:16px;top:50%;transform:translateY(-50%);
    color:#3f3f46;pointer-events:none;
  }
  .gate-btn{
    width:100%;
    background:linear-gradient(135deg,#d4a843 0%,#c49a35 50%,#b8922e 100%);
    border:none;
    color:#0a0a0a;
    padding:14px 24px;
    border-radius:12px;
    font-size:14px;
    font-weight:700;
    font-family:inherit;
    cursor:pointer;
    letter-spacing:0.5px;
    transition:all .2s ease;
    position:relative;
    overflow:hidden;
  }
  .gate-btn:hover{
    transform:translateY(-1px);
    box-shadow:0 8px 24px rgba(212,168,67,0.2);
  }
  .gate-btn:active{transform:translateY(0)}
  .gate-btn::after{
    content:'';position:absolute;top:0;left:-100%;
    width:100%;height:100%;
    background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent);
    transition:left .5s ease;
  }
  .gate-btn:hover::after{left:100%}
  .gate-err{
    color:#ef4444;
    font-size:12px;
    margin-top:14px;
    opacity:0;
    transform:translateY(-4px);
    transition:all .2s ease;
    font-weight:500;
  }
  .gate-err.show{
    opacity:1;
    transform:translateY(0);
  }
  .gate-footer{
    margin-top:32px;
    padding-top:24px;
    border-top:1px solid rgba(30,30,46,0.5);
    display:flex;
    align-items:center;
    justify-content:center;
    gap:6px;
    color:#3f3f46;
    font-size:11px;
    letter-spacing:0.5px;
  }
  .gate-footer .dot{
    width:4px;height:4px;border-radius:50%;
    background:#22c55e;
    box-shadow:0 0 6px rgba(34,197,94,0.5);
  }
  /* Loading state */
  .gate-btn.loading{pointer-events:none;opacity:0.7}
  .gate-btn.loading .btn-text{opacity:0}
  .gate-btn.loading .spinner{display:block}
  .spinner{
    display:none;position:absolute;
    top:50%;left:50%;transform:translate(-50%,-50%);
    width:18px;height:18px;
    border:2px solid rgba(10,10,15,0.3);
    border-top-color:#0a0a0a;
    border-radius:50%;
    animation:spin .6s linear infinite;
  }
  @keyframes spin{to{transform:translate(-50%,-50%) rotate(360deg)}}
  /* Shake animation */
  @keyframes shake{
    0%,100%{transform:translateX(0)}
    20%,60%{transform:translateX(-6px)}
    40%,80%{transform:translateX(6px)}
  }
  .shake{animation:shake .4s ease}
</style>
</head>
<body>
<div class="gate-container">
  <div class="gate-card" id="gateCard">
    <div class="gate-mark">⚔️</div>
    <div class="gate-brand">KNIGHT OPS</div>
    <div class="gate-title">Command Center</div>
    <div class="gate-sub">Authorized access only</div>
    <form id="gateForm" onsubmit="return handleSubmit(event)">
      <div class="input-group">
        <svg class="input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <input type="password" class="gate-input" id="passInput" placeholder="Enter passcode" autofocus autocomplete="off">
      </div>
      <button type="submit" class="gate-btn" id="gateBtn">
        <span class="btn-text">ACCESS DASHBOARD</span>
        <div class="spinner"></div>
      </button>
    </form>
    <div class="gate-err" id="gateErr">Incorrect passcode</div>
    <div class="gate-footer">
      <span class="dot"></span>
      <span>ENCRYPTED • SECURE • PRIVATE</span>
    </div>
  </div>
</div>
<script>
var D="";
function handleSubmit(e){
  e.preventDefault();
  var btn=document.getElementById('gateBtn');
  var err=document.getElementById('gateErr');
  var card=document.getElementById('gateCard');
  var p=document.getElementById('passInput').value;
  btn.classList.add('loading');
  err.classList.remove('show');
  setTimeout(function(){
    if(p==='Abundance2782!!'){
      try{
        var html=atob(D);
        document.open();
        document.write(html);
        document.close();
      }catch(ex){
        btn.classList.remove('loading');
        err.textContent='Error loading dashboard';
        err.classList.add('show');
      }
    }else{
      btn.classList.remove('loading');
      err.classList.add('show');
      card.classList.add('shake');
      setTimeout(function(){card.classList.remove('shake')},400);
      document.getElementById('passInput').value='';
      document.getElementById('passInput').focus();
    }
  },600);
  return false;
}
document.getElementById('passInput').addEventListener('keydown',function(){
  document.getElementById('gateErr').classList.remove('show');
});
</script>
</body>
</html>
